# LinuxLab — Environment Variables
# Copy to .env and configure before starting:
#   cp .env.example .env
#
# Generate secrets:
#   openssl rand -hex 32          # SECRET_KEY
#   openssl rand -base64 12       # DEFAULT_ADMIN_PASS
#
# ALL variables marked with ⚠ are REQUIRED — startup will fail if missing.

# ── Security ⚠ ──────────────────────────────────────
SECRET_KEY=cambiar-por-clave-segura-aqui   # ⚠ Generate: openssl rand -hex 32
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASS=cambiar-en-produccion   # ⚠ Generate: openssl rand -base64 12

# ── Database ⚠ ─────────────────────────────────────
MARIADB_ROOT_PASSWORD=cambiar-en-produccion  # ⚠
MARIADB_DATABASE=linuxlab
MARIADB_USER=linuxlab
MARIADB_PASSWORD=cambiar-en-produccion       # ⚠
# Internal DSN used by backend (auto-built from MariaDB vars above — override if different)
# DATABASE_URL=mysql+aiomysql://linuxlab:cambiar-en-produccion@127.0.0.1:3306/linuxlab

# ── Host IP ⚠ ──────────────────────────────────────
HOST_IP=192.168.1.100   # ⚠ IP real del servidor (para iptables DNAT)

# ── Frontend / CORS ─────────────────────────────────
CORS_ORIGINS=["http://localhost", "https://localhost", "http://192.168.1.100", "https://192.168.1.100"]

# ── JWT ─────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Email ───────────────────────────────────────────
EMAIL_DOMAIN=linuxlab.local

# ── Database Pool ───────────────────────────────────
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# ── Cache ───────────────────────────────────────────
CONFIG_CACHE_TTL=60
METRICS_CACHE_TTL=10

# ── libvirt ──────────────────────────────────────────
LIBVIRT_URI=qemu:///system
LIBVIRT_POOL=images
VM_MAC_PREFIX=52:54:00:35:E0

# ── VM Network ──────────────────────────────────────
VM_SUBNET=192.168.122
VM_BRIDGE=virbr0
VM_NETWORK=default
STORAGE_PATH=/var/lib/libvirt/images

# ── SSH ─────────────────────────────────────────────
VM_SSH_USER=estudiante
# Optional: path to SSH keys for VM access
# VM_SSH_KEY_DIR=/home/user/.ssh
