# LinuxLab — Variables de Entorno
# Copiar a .env y ajustar

# Seguridad (CAMBIAR en producción)
SECRET_KEY=cambiar-por-clave-segura-aqui

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — IP/dominio del frontend
CORS_ORIGINS=["http://localhost:5173"]

# Red de VMs (subred libvirt). Por defecto 192.168.122
# VM_SUBNET=192.168.122

# IP real del servidor (se auto-detecta si no se define)
# HOST_IP=192.168.1.100

# Usuario SSH para terminal web
# VM_SSH_USER=estudiante

# Bridge, red libvirt y ruta de almacenamiento
# VM_BRIDGE=virbr0
# VM_NETWORK=default
# STORAGE_PATH=/var/lib/libvirt/images
