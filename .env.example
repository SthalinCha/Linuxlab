# LinuxLab — Variables de Entorno
# Copiar a .env y ajustar antes de docker compose up
#   cp .env.example .env

# ── Seguridad (CAMBIAR en producción) ─────────────────
SECRET_KEY=cambiar-por-clave-segura-aqui
# Generar con: openssl rand -hex 32

# ── Base de datos MariaDB ────────────────────────────
MARIADB_ROOT_PASSWORD=linuxlab_root
MARIADB_DATABASE=linuxlab
MARIADB_USER=linuxlab
MARIADB_PASSWORD=linuxlab_pass

# ── JWT ─────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS (frontend URL) ─────────────────────────────
CORS_ORIGINS=["http://localhost:5173", "http://localhost"]

# ── Frontend (Vite) ─────────────────────────────────
# Ruta base del API (default: /api/v1 con proxy de Vite)
VITE_API_URL=/api/v1

# ── Red de VMs (libvirt) ────────────────────────────
VM_SUBNET=192.168.122
VM_BRIDGE=virbr0
VM_NETWORK=default
STORAGE_PATH=/var/lib/libvirt/images

# ── SSH para terminal web ──────────────────────────
VM_SSH_USER=estudiante

# ── IP del servidor (auto-detectada si no se define) ─
# HOST_IP=192.168.1.100
